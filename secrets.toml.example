# ==========================================================
# Fraud Buster Challenge - Configuration Example
# Copy this file to fraud-buster-app/.streamlit/secrets.toml
# ==========================================================
# Note: Keep the double quotes

# Database Connection Details
DB_USER = "YOUR_ADB_USER"
DB_PASSWORD = "YOUR_ADB_PASSWORD"
DB_DSN = "yourdatabase_high"  # The name from your TNSNames.ora file

# Wallet Configuration
# The directory relative to fraud-buster-app/ where your unzipped wallet is located
WALLET_DIR = "adb_wallet"
WALLET_PASSWORD = "your-wallet-password"

# Replace: If you named your Select AI profile differently
AI_PROFILE = "FRAUD_BUSTER_AI"
